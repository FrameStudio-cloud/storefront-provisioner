function SearchBar({ value, onChange, placeholder }) {
  return (
    <div className="relative">
      <MagnifyingGlass
        size={18}
        className="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"
      />
      <input
        type="text"
        value={value}
        onChange={(e) => onChange(e.target.value)}
        placeholder={placeholder || 'Search products...'}
        className="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl text-sm text-gray-900 placeholder-gray-400 focus:outline-none transition-shadow"
        onFocus={(e) => {
          e.target.style.boxShadow = `0 0 0 2px ${COLORS.accent}33`
          e.target.style.borderColor = COLORS.accent
        }}
        onBlur={(e) => {
          e.target.style.boxShadow = ''
          e.target.style.borderColor = ''
        }}
      />
    </div>
  )
}

function CategoryChips({ categories, selected, onChange }) {
  const all = ['All', ...categories]

  return (
    <div className="flex gap-2 overflow-x-auto pb-2 scrollbar-none -mx-4 px-4 sm:mx-0 sm:px-0">
      {all.map((cat) => {
        const isActive = cat === selected || (!selected && cat === 'All')
        return (
          <button
            key={cat}
            onClick={() => onChange(cat === 'All' ? '' : cat)}
            className={`flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-all whitespace-nowrap ${
              isActive
                ? 'text-white shadow-sm'
                : 'text-gray-600 bg-gray-100 hover:bg-gray-200'
            }`}
            style={isActive ? { backgroundColor: COLORS.primary } : {}}
          >
            {cat}
            {cat !== 'All' && (
              <span className="ml-1 text-xs opacity-70">
                ({c.catalogue.filter((item) => item.category === cat).length})
              </span>
            )}
          </button>
        )
      })}
    </div>
  )
}

function ProductCard({ item }) {
  const navigate = useNavigate()

  return (
    <article
      className="product-card bg-white rounded-xl border border-gray-100 overflow-hidden cursor-pointer"
      onClick={() => navigate(`/product/${item.id}`)}
      role="button"
      tabIndex={0}
      onKeyDown={(e) => {
        if (e.key === 'Enter' || e.key === ' ') navigate(`/product/${item.id}`)
      }}
    >
      <div className="relative aspect-square overflow-hidden bg-gray-50">
        <ImageWithFallback
          src={item.image?.src}
          alt={item.title}
          className="w-full h-full object-cover"
          initials={item.title?.charAt(0)}
        />
        {item.badge && (
          <span
            className="absolute top-2 left-2 px-2.5 py-1 rounded-md text-xs font-semibold text-white"
            style={{ backgroundColor: COLORS.accent }}
          >
            {item.badge}
          </span>
        )}
      </div>
      <div className="p-4">
        <h3 className="text-sm font-semibold text-gray-900 line-clamp-2 leading-snug min-h-[2.5em]">
          {item.title}
        </h3>
        <p className="mt-1.5 text-base font-bold" style={{ color: COLORS.primary }}>
          {c.currency} {Number(item.price).toLocaleString()}
        </p>
        {item.category && (
          <span className="mt-1.5 inline-block text-xs text-gray-400 bg-gray-50 px-2 py-0.5 rounded">
            {item.category}
          </span>
        )}
      </div>
    </article>
  )
}

function EmptyState({ searchTerm }) {
  return (
    <div className="text-center py-16">
