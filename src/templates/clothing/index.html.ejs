<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%= (tagline || description || name) %>" />
  <meta property="og:title" content="<%= name %> — Fashion Storefront" />
  <meta property="og:description" content="<%= (tagline || description || name) %>" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://<%= (websiteUrl || name.toLowerCase().replace(/\s+/g, '-') + '.keel.framestudio.co.ke') %>" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= name %> — Fashion Storefront" />
  <meta name="twitter:description" content="<%= (tagline || description || name) %>" />
  <title><%= name %> — Fashion</title>
  <style>
    :root {
      --color-primary: <%= primaryColor %>;
      --color-accent: <%= accentColor %>;
    }
  </style>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ClothingStore",
    "name": "<%= (name || '').replace(/"/g, '\\"') %>",
    "description": "<%= ((tagline || description || name) || '').replace(/"/g, '\\"') %>",
    "url": "https://<%= (websiteUrl || name.toLowerCase().replace(/\s+/g, '-') + '.keel.framestudio.co.ke') %>",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "<%= whatsapp || '' %>",
      "contactType": "sales"
    },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "<%= (address || location || '').replace(/"/g, '\\"') %>"
    }
  }
  </script>
</head>
<body>
  <div id="root"></div>
  <script type="module" src="/src/main.jsx"></script>
</body>
</html>
