function Container({ children, className = '' }) {
  return (
    <div className={`max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 ${className}`}>
      {children}
    </div>
  )
}

function Section({ children, bg = '', className = '', id }) {
  return (
    <section id={id} className={`py-16 md:py-24 ${bg} ${className}`}>
      <Container>{children}</Container>
    </section>
  )
}

function ImageWithFallback({ src, alt, className = '', initials }) {
  const [error, setError] = useState(false)
  if (!src || error) {
    return (
      <div
        className={`bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center ${className}`}
        aria-label={alt || 'Image placeholder'}
      >
        <span className="text-gray-400 text-lg font-semibold select-none">
          {initials || (alt ? alt.charAt(0).toUpperCase() : '?')}
        </span>
      </div>
    )
  }
  return (
    <img
      src={src}
      alt={alt || ''}
      className={className}
      onError={() => setError(true)}
      loading="lazy"
    />
  )
}

function AnnouncementBar({ text, type }) {
  const [dismissed, setDismissed] = useState(false)
  if (dismissed || !text) return null

  const styles = {
    sale: 'bg-red-50 text-red-800 border-red-200',
    warning: 'bg-amber-50 text-amber-800 border-amber-200',
    info: 'bg-blue-50 text-blue-800 border-blue-200',
    alert: 'bg-purple-50 text-purple-800 border-purple-200',
  }

  return (
    <div className={`${styles[type] || styles.info} border-b text-sm py-2.5 px-4 text-center relative`}>
      <span className="font-medium">{text}</span>
      <button
        onClick={() => setDismissed(true)}
        className="absolute right-3 top-1/2 -translate-y-1/2 p-1 text-current opacity-50 hover:opacity-100 transition-opacity"
        aria-label="Dismiss announcement"
      >
        <X size={14} weight="bold" />
      </button>
    </div>
  )
}

