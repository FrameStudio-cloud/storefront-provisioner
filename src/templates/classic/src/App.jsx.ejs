function WhatsAppFloat() {
  const [visible, setVisible] = useState(false)

  useEffect(() => {
    const handleScroll = () => setVisible(window.scrollY > 200)
    window.addEventListener('scroll', handleScroll, { passive: true })
    return () => window.removeEventListener('scroll', handleScroll)
  }, [])

  if (!c.whatsapp) return null

  return (
    <a
      href={`https://wa.me/${c.whatsapp}`}
      target="_blank"
      rel="noopener noreferrer"
      className={`whatsapp-float fixed bottom-6 right-6 z-40 flex items-center gap-2 px-4 py-3 rounded-full text-white shadow-lg hover:shadow-xl transition-shadow ${
        visible ? 'opacity-100 pointer-events-auto' : 'opacity-0 pointer-events-none'
      }`}
      style={{ backgroundColor: '#25D366' }}
      aria-label="Chat on WhatsApp"
    >
      <WhatsappLogo size={20} weight="fill" />
      <span className="text-sm font-medium hidden sm:inline">Chat on WhatsApp</span>
    </a>
  )
}

function BackToTop() {
  const [visible, setVisible] = useState(false)

  useEffect(() => {
    const handleScroll = () => setVisible(window.scrollY > 400)
    window.addEventListener('scroll', handleScroll, { passive: true })
    return () => window.removeEventListener('scroll', handleScroll)
  }, [])

  return (
    <button
      onClick={() => window.scrollTo({ top: 0, behavior: 'smooth' })}
      className={`back-to-top fixed bottom-6 left-6 z-40 p-3 rounded-full bg-white border border-gray-200 shadow-sm hover:shadow-md text-gray-600 hover:text-gray-900 transition-all ${
        visible ? 'opacity-100 pointer-events-auto' : 'opacity-0 pointer-events-none'
      }`}
      aria-label="Back to top"
    >
      <CaretUp size={18} />
    </button>
  )
}

function ProductDetail() {
  const { id } = useParams()
  const navigate = useNavigate()
  const product = c.catalogue.find((item) => String(item.id) === String(id))

  useEffect(() => {
    document.title = product ? `${product.title} — ${c.name}` : `Product not found — ${c.name}`
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }, [product])

  if (!product) {
    return (
      <Section>
        <div className="text-center py-16">
          <div className="w-16 h-16 mx-auto rounded-full bg-gray-100 flex items-center justify-center mb-4">
            <span className="text-2xl text-gray-400 font-semibold">?</span>
          </div>
          <h2 className="text-xl font-semibold text-gray-900">Product not found</h2>
          <p className="mt-2 text-sm text-gray-500">
            This product may have been removed or is no longer available.
          </p>
          <button
            onClick={() => navigate('/')}
            className="mt-6 inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium text-white transition-colors"
            style={{ backgroundColor: COLORS.primary }}
          >
            <CaretLeft size={16} />
            Back to Catalogue
          </button>
        </div>
      </Section>
    )
  }

  const related = c.catalogue.filter(
    (item) => item.id !== product.id && item.category === product.category && item.available !== false
  ).slice(0, 4)

  return (
    <Section>
      <button
        onClick={() => navigate('/')}
        className="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900 transition-colors mb-6"
      >
        <CaretLeft size={16} />
        Back to Catalogue
      </button>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <div className="rounded-xl overflow-hidden bg-gray-50">
          <ImageWithFallback
            src={product.image?.src}
            alt={product.title}
            className="w-full h-full max-h-[500px] object-contain"
            initials={product.title?.charAt(0)}
          />
        </div>
        <div className="flex flex-col">
          {product.badge && (
            <span
              className="inline-self-start px-3 py-1 rounded-md text-xs font-semibold text-white mb-3"
              style={{ backgroundColor: COLORS.accent }}
            >
              {product.badge}
            </span>
          )}
          <h1 className="text-2xl sm:text-3xl font-bold text-gray-900 leading-tight">
            {product.title}
          </h1>
          <p className="mt-3 text-2xl font-bold" style={{ color: COLORS.primary }}>
            {c.currency} {Number(product.price).toLocaleString()}
          </p>
          {product.description && (
            <p className="mt-4 text-sm text-gray-600 leading-relaxed">
              {product.description}
            </p>
          )}
          {product.specs && product.specs.length > 0 && (
            <div className="mt-6">
              <h3 className="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">
                Specifications
              </h3>
              <div className="divide-y divide-gray-100 border border-gray-100 rounded-lg overflow-hidden">
                {product.specs.map((spec, i) => (
                  <div key={i} className="flex px-4 py-2.5 text-sm">
                    <span className="w-1/2 text-gray-500 font-medium">{spec.label || spec.name}</span>
                    <span className="w-1/2 text-gray-900">{spec.value}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
          {product.includes && product.includes.length > 0 && (
            <div className="mt-6">
              <h3 className="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">
                What's Included
              </h3>
              <ul className="space-y-1.5">
                {product.includes.map((item, i) => (
                  <li key={i} className="flex items-start gap-2 text-sm text-gray-600">
                    <span className="mt-0.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style={{ backgroundColor: COLORS.accent }} />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )}
          <div className="mt-auto pt-6">
            <a
              href={`https://wa.me/${c.whatsapp}?text=${encodeURIComponent(`Hi, I'm interested in ${product.title} (${c.currency} ${Number(product.price).toLocaleString()})`)}`}
              target="_blank"
              rel="noopener noreferrer"
              className="flex items-center justify-center gap-2 w-full px-6 py-3.5 rounded-xl text-base font-semibold text-white transition-colors"
              style={{ backgroundColor: '#25D366' }}
            >
              <WhatsappLogo size={20} weight="fill" />
              Order via WhatsApp
            </a>
          </div>
        </div>
      </div>
    </Section>
  )
}

function RelatedProducts() {
  const { id } = useParams()
  const product = c.catalogue.find((item) => String(item.id) === String(id))
  if (!product) return null

  const related = c.catalogue.filter(
    (item) => item.id !== product.id && item.category === product.category && item.available !== false
  ).slice(0, 4)

  if (related.length === 0) return null

  return (
    <Section bg="bg-gray-50">
      <h2 className="text-xl sm:text-2xl font-bold text-gray-900 mb-8">
        You Might Also Like
      </h2>
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {related.map((item) => (
          <ProductCard key={item.id} item={item} />
        ))}
      </div>
    </Section>
  )
}

function HomePage() {
  return (
    <div className="min-h-screen bg-white">
<% if (announcements.length > 0) { %>
      {c.announcements.map((a, i) => (
        <AnnouncementBar key={i} text={a.text} type={a.type} />
      ))}
<% } %>
      <Nav />
      <Hero />
<% if (about) { %>
      <AboutSection />
<% } %>
<% if (catalogue.length > 0) { %>
      <CatalogueSection />
<% } %>
      <Footer />
      <WhatsAppFloat />
      <BackToTop />
    </div>
  )
}

function ProductPage() {
  return (
    <div className="min-h-screen bg-white">
      <Nav />
      <ProductDetail />
      <RelatedProducts />
      <Footer />
      <WhatsAppFloat />
      <BackToTop />
    </div>
  )
}

export default function App() {
  return (
    <Routes>
      <Route path="/" element={<HomePage />} />
      <Route path="/product/:id" element={<ProductPage />} />
    </Routes>
  )
}
