}

function CatalogueSection() {
  const [search, setSearch] = useState('')
  const [selectedCategory, setSelectedCategory] = useState('')

  const filtered = useMemo(() => {
    let result = c.catalogue.filter((item) => item.available !== false)
    if (search.trim()) {
      const q = search.toLowerCase()
      result = result.filter(
        (item) =>
          item.title.toLowerCase().includes(q) ||
          (item.category && item.category.toLowerCase().includes(q)) ||
          (item.description && item.description.toLowerCase().includes(q))
      )
    }
    if (selectedCategory) {
      result = result.filter((item) => item.category === selectedCategory)
    }
    return result
  }, [search, selectedCategory])

  return (
    <Section bg="bg-gray-50" id="catalogue">
      <div>
        <div className="text-center mb-10">
          <h2 className="text-2xl sm:text-3xl font-bold text-gray-900">
            Our Catalogue
          </h2>
          <p className="mt-2 text-gray-500 max-w-xl mx-auto">
            Browse our products and order directly via WhatsApp
          </p>
        </div>

        <div className="max-w-md mx-auto mb-6">
          <SearchBar
            value={search}
            onChange={setSearch}
            placeholder="Search products..."
          />
        </div>

        {c.categories && c.categories.length > 0 && (
          <div className="mb-8">
            <CategoryChips
              categories={c.categories}
              selected={selectedCategory}
              onChange={setSelectedCategory}
            />
          </div>
        )}

        <div className="flex items-center justify-between mb-4">
          <p className="text-sm text-gray-500">
            Showing {filtered.length} of {c.catalogue.length} products
          </p>
        </div>

        {filtered.length > 0 ? (
          <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
            {filtered.map((item) => (
              <ProductCard key={item.id} item={item} />
            ))}
          </div>
        ) : (
          <EmptyState searchTerm={search} />
        )}
      </div>
    </Section>
  )
}

