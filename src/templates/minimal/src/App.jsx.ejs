import { useState, useEffect, useMemo, useCallback } from 'react'
import { Routes, Route, useParams, useNavigate } from 'react-router-dom'
import {
  X, List, CaretLeft, CaretRight, MapPin,
  Envelope, Clock, CaretUp, MagnifyingGlass, WhatsappLogo,
  InstagramLogo, FacebookLogo, Globe,
} from '@phosphor-icons/react'
import shopConfig from './config/site'

const c = shopConfig

const COLORS = {
  primary: c.primaryColor || '#1e293b',
  accent: c.accentColor || '#0ea5e9',
}

function Container({ children, className = '' }) {
  return (
    <div className={`max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 ${className}`}>
      {children}
    </div>
  )
}

function Nav() {
  const [open, setOpen] = useState(false)
  const [scrolled, setScrolled] = useState(false)
  useEffect(() => {
    const onScroll = () => setScrolled(window.scrollY > 20)
    window.addEventListener('scroll', onScroll, { passive: true })
    return () => window.removeEventListener('scroll', onScroll)
  }, [])

  return (
    <nav className={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${scrolled ? 'bg-white/95 backdrop-blur-md shadow-sm' : 'bg-transparent'}`}>
      <Container className="flex items-center justify-between h-16">
        <a href="/" className="text-lg font-bold text-gray-900">
          {c.name}
        </a>
        <div className="hidden sm:flex items-center gap-6">
          <a href="/" className="text-sm text-gray-600 hover:text-gray-900 transition-colors">Home</a>
          <a href="/#catalogue" className="text-sm text-gray-600 hover:text-gray-900 transition-colors">Products</a>
          {c.whatsapp && (
            <a href={`https://wa.me/${c.whatsapp}`} target="_blank" rel="noopener noreferrer"
              className="text-sm font-medium text-white px-4 py-1.5 rounded-lg transition-colors"
              style={{ backgroundColor: COLORS.accent }}>
              Contact
            </a>
          )}
        </div>
        <button className="sm:hidden p-2" onClick={() => setOpen(!open)} aria-label="Menu">
          {open ? <X size={22} /> : <List size={22} />}
        </button>
      </Container>
      {open && (
        <div className="sm:hidden bg-white border-t border-gray-100 px-4 pb-4 space-y-3">
          <a href="/" className="block text-sm text-gray-600 pt-3" onClick={() => setOpen(false)}>Home</a>
          <a href="/#catalogue" className="block text-sm text-gray-600" onClick={() => setOpen(false)}>Products</a>
          {c.whatsapp && (
            <a href={`https://wa.me/${c.whatsapp}`} target="_blank" rel="noopener noreferrer"
              className="block text-sm font-medium text-white px-4 py-2 rounded-lg text-center transition-colors"
              style={{ backgroundColor: COLORS.accent }}>
              Contact
            </a>
          )}
        </div>
      )}
    </nav>
  )
}

function ImageWithFallback({ src, alt, className = '', initials }) {
  const [errored, setErrored] = useState(false)
  if (!src || errored) {
    return (
      <div className={`flex items-center justify-center bg-gray-100 ${className}`}>
        <span className="text-2xl font-bold text-gray-300">{initials || '?'}</span>
      </div>
    )
  }
  return <img src={src} alt={alt} className={className} loading="lazy" onError={() => setErrored(true)} />
}

function HeroBanner() {
  const firstSlide = c.slides?.[0]
  return (
    <section className="pt-16">
      <div className="bg-gradient-to-br from-gray-50 to-gray-100 border-b border-gray-100">
        <Container className="py-16 sm:py-24 text-center">
          {firstSlide?.tag && (
            <span className="inline-block text-xs font-semibold tracking-widest uppercase mb-3 px-3 py-1 rounded-full"
              style={{ backgroundColor: COLORS.accent + '15', color: COLORS.accent }}>
              {firstSlide.tag}
            </span>
          )}
          <h1 className="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight mb-4">
            {firstSlide?.title || c.name}
          </h1>
          <p className="text-base sm:text-lg text-gray-500 max-w-xl mx-auto leading-relaxed mb-6">
            {firstSlide?.description || c.tagline || c.description || 'Browse our collection'}
          </p>
          <a href="/#catalogue"
            className="inline-flex items-center gap-2 px-6 py-3 text-white font-medium rounded-xl text-sm transition-all"
            style={{ backgroundColor: COLORS.primary }}>
            Browse Products <CaretRight size={16} />
          </a>
        </Container>
      </div>
    </section>
  )
}

function SearchBar({ value, onChange }) {
  return (
    <div className="relative max-w-md mx-auto">
      <MagnifyingGlass size={18} className="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400" />
      <input
        type="text"
        value={value}
        onChange={(e) => onChange(e.target.value)}
        placeholder="Search products..."
        className="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none"
        onFocus={(e) => { e.target.style.borderColor = COLORS.accent }}
        onBlur={(e) => { e.target.style.borderColor = '' }}
      />
    </div>
  )
}

function ProductCard({ item }) {
  const navigate = useNavigate()
  return (
    <article
      className="bg-white rounded-lg border border-gray-100 overflow-hidden cursor-pointer transition-all hover:shadow-md"
      onClick={() => navigate(`/product/${item.id}`)}
      role="button"
      tabIndex={0}
      onKeyDown={(e) => { if (e.key === 'Enter' || e.key === ' ') navigate(`/product/${item.id}`) }}
    >
      <div className="relative aspect-square overflow-hidden bg-gray-50">
        <ImageWithFallback
          src={item.image?.src}
          alt={item.title}
          className="w-full h-full object-cover"
          initials={item.title?.charAt(0)}
        />
        {item.badge && (
          <span className="absolute top-2 left-2 px-2 py-0.5 rounded text-xs font-medium text-white"
            style={{ backgroundColor: COLORS.accent }}>
            {item.badge}
          </span>
        )}
      </div>
      <div className="p-3.5">
        <h3 className="text-sm font-medium text-gray-900 line-clamp-2 leading-snug">{item.title}</h3>
        <p className="mt-1 text-base font-semibold" style={{ color: COLORS.primary }}>
          {c.currency} {Number(item.price).toLocaleString()}
        </p>
        {item.category && (
          <span className="mt-1.5 inline-block text-xs text-gray-400 bg-gray-50 px-2 py-0.5 rounded">{item.category}</span>
        )}
      </div>
    </article>
  )
}

function EmptyState({ searchTerm }) {
  return (
    <div className="text-center py-12">
      <div className="w-12 h-12 mx-auto rounded-full bg-gray-100 flex items-center justify-center mb-3">
        <MagnifyingGlass size={20} className="text-gray-400" />
      </div>
      <p className="text-sm text-gray-500">
        {searchTerm ? `No products matching "${searchTerm}"` : 'No products yet'}
      </p>
    </div>
  )
}

function CatalogueSection() {
  const [search, setSearch] = useState('')
  const [selectedCategory, setSelectedCategory] = useState('')

  const filtered = useMemo(() => {
    let result = c.catalogue.filter((item) => item.available !== false)
    if (search.trim()) {
      const q = search.toLowerCase()
      result = result.filter(
        (item) =>
          item.title.toLowerCase().includes(q) ||
          (item.category && item.category.toLowerCase().includes(q))
      )
    }
    if (selectedCategory) {
      result = result.filter((item) => item.category === selectedCategory)
    }
    return result
  }, [search, selectedCategory])

  return (
    <section id="catalogue" className="py-12 sm:py-16">
      <Container>
        <div className="text-center mb-8">
          <h2 className="text-xl sm:text-2xl font-bold text-gray-900">Our Products</h2>
          <p className="mt-1 text-sm text-gray-500">{c.catalogue.length} items available</p>
        </div>
        <SearchBar value={search} onChange={setSearch} />
        {c.categories.length > 0 && (
          <div className="mt-4 flex flex-wrap gap-2 justify-center">
            <button
              onClick={() => setSelectedCategory('')}
              className={`px-3 py-1 rounded-full text-xs font-medium transition-colors ${!selectedCategory ? 'text-white' : 'text-gray-600 bg-gray-100 hover:bg-gray-200'}`}
              style={!selectedCategory ? { backgroundColor: COLORS.primary } : {}}>
              All
            </button>
            {c.categories.map((cat) => (
              <button key={cat}
                onClick={() => setSelectedCategory(cat)}
                className={`px-3 py-1 rounded-full text-xs font-medium transition-colors ${selectedCategory === cat ? 'text-white' : 'text-gray-600 bg-gray-100 hover:bg-gray-200'}`}
                style={selectedCategory === cat ? { backgroundColor: COLORS.primary } : {}}>
                {cat}
              </button>
            ))}
          </div>
        )}
        <div className="mt-6">
          {filtered.length > 0 ? (
            <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
              {filtered.map((item) => (
                <ProductCard key={item.id} item={item} />
              ))}
            </div>
          ) : (
            <EmptyState searchTerm={search} />
          )}
        </div>
      </Container>
    </section>
  )
}

function Footer() {
  return (
    <footer className="border-t border-gray-100 bg-gray-50">
      <Container className="py-8 sm:py-10">
        <div className="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div>
            <h3 className="font-semibold text-gray-900 text-sm mb-3">{c.name}</h3>
            <p className="text-xs text-gray-500 leading-relaxed">{c.tagline || c.description || ''}</p>
          </div>
          <div>
            <h3 className="font-semibold text-gray-900 text-sm mb-3">Contact</h3>
            <div className="space-y-2 text-xs text-gray-500">
              {c.email && <div className="flex items-center gap-2"><Envelope size={14} />{c.email}</div>}
              {c.phone && <div className="flex items-center gap-2"><WhatsappLogo size={14} />{c.phone}</div>}
              {c.location && <div className="flex items-center gap-2"><MapPin size={14} />{c.location}</div>}
              {c.hours.length > 0 && <div className="flex items-center gap-2"><Clock size={14} />{c.hours[0].day} {c.hours[0].hours}</div>}
            </div>
          </div>
          <div>
            <h3 className="font-semibold text-gray-900 text-sm mb-3">Follow Us</h3>
            <div className="flex gap-3">
              {c.socialLinks.map((link) => (
                <a key={link.label} href={link.href} target="_blank" rel="noopener noreferrer"
                  className="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center text-gray-500 hover:text-gray-700 transition-colors">
                  {link.icon === 'instagram' && <InstagramLogo size={16} />}
                  {link.icon === 'facebook' && <FacebookLogo size={16} />}
                  {link.icon === 'tiktok' && <Globe size={16} />}
                </a>
              ))}
            </div>
          </div>
        </div>
        <div className="mt-6 pt-6 border-t border-gray-200 text-center text-xs text-gray-400">
          &copy; {new Date().getFullYear()} {c.name}. Powered by <a href="https://keel.framestudio.co.ke" className="underline" target="_blank" rel="noopener noreferrer">Keel</a>
        </div>
      </Container>
    </footer>
  )
}

function WhatsAppFloat() {
  if (!c.whatsapp) return null
  return (
    <a
      href={`https://wa.me/${c.whatsapp}`}
      target="_blank"
      rel="noopener noreferrer"
      className="whatsapp-float fixed bottom-6 right-6 z-40 w-14 h-14 rounded-full shadow-lg flex items-center justify-center text-white transition-transform hover:scale-110"
      style={{ backgroundColor: '#25D366' }}
      aria-label="Chat on WhatsApp"
    >
      <WhatsappLogo size={26} weight="fill" />
    </a>
  )
}

function BackToTop() {
  const [visible, setVisible] = useState(false)
  useEffect(() => {
    const onScroll = () => setVisible(window.scrollY > 400)
    window.addEventListener('scroll', onScroll, { passive: true })
    return () => window.removeEventListener('scroll', onScroll)
  }, [])
  return visible ? (
    <button
      onClick={() => window.scrollTo({ top: 0, behavior: 'smooth' })}
      className="back-to-top fixed bottom-6 left-6 z-40 w-10 h-10 rounded-full bg-white border border-gray-200 shadow-md flex items-center justify-center text-gray-500 hover:text-gray-900 transition-colors"
      aria-label="Back to top"
    >
      <CaretUp size={18} />
    </button>
  ) : null
}

function ProductDetail() {
  const { id } = useParams()
  const navigate = useNavigate()
  const item = useMemo(() => c.catalogue.find((p) => p.id === id), [id])
  const [currentImage, setCurrentImage] = useState(0)

  if (!item) {
    return (
      <div className="pt-20 pb-12 text-center">
        <p className="text-gray-500">Product not found</p>
        <button onClick={() => navigate('/')} className="mt-4 text-sm underline">Back to home</button>
      </div>
    )
  }

  const images = [item.image?.src].filter(Boolean)

  return (
    <div className="pt-16">
      <Container className="py-8">
        <button onClick={() => navigate('/')} className="flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-6 transition-colors">
          <CaretLeft size={16} /> Back
        </button>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
          <div>
            <div className="aspect-square rounded-lg overflow-hidden bg-gray-50 mb-3">
              <ImageWithFallback
                src={images[currentImage]}
                alt={item.title}
                className="w-full h-full object-cover"
                initials={item.title?.charAt(0)}
              />
            </div>
            {images.length > 1 && (
              <div className="flex gap-2 overflow-x-auto">
                {images.map((img, i) => (
                  <button key={i}
                    onClick={() => setCurrentImage(i)}
                    className={`w-16 h-16 rounded-md overflow-hidden border-2 flex-shrink-0 transition-colors ${currentImage === i ? 'border-gray-900' : 'border-transparent'}`}>
                    <ImageWithFallback src={img} alt="" className="w-full h-full object-cover" initials=""/>
                  </button>
                ))}
              </div>
            )}
          </div>
          <div>
            {item.badge && (
              <span className="inline-block text-xs font-medium text-white px-2.5 py-1 rounded mb-3"
                style={{ backgroundColor: COLORS.accent }}>{item.badge}</span>
            )}
            <h1 className="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">{item.title}</h1>
            <p className="text-2xl font-bold mb-4" style={{ color: COLORS.primary }}>
              {c.currency} {Number(item.price).toLocaleString()}
            </p>
            {item.description && (
              <p className="text-sm text-gray-600 leading-relaxed mb-6">{item.description}</p>
            )}
            {item.specs.length > 0 && (
              <div className="mb-6">
                <h3 className="text-sm font-semibold text-gray-900 mb-2">Specifications</h3>
                <ul className="space-y-1">
                  {item.specs.map((spec, i) => (
                    <li key={i} className="text-sm text-gray-500 flex items-center gap-2">
                      <span className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: COLORS.accent }} />
                      {typeof spec === 'string' ? spec : `${spec.label || spec.name}: ${spec.value}`}
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {item.variants.length > 0 && (
              <div className="mb-6">
                <h3 className="text-sm font-semibold text-gray-900 mb-2">Available Options</h3>
                <div className="flex flex-wrap gap-2">
                  {item.variants.map((v, i) => (
                    <span key={i} className="text-xs px-3 py-1.5 bg-gray-50 border border-gray-100 rounded-lg text-gray-600">
                      {v.label || v.name || v}
                    </span>
                  ))}
                </div>
              </div>
            )}
            {c.whatsapp && (
              <a href={`https://wa.me/${c.whatsapp}?text=Hi%2C%20I%27m%20interested%20in%20${encodeURIComponent(item.title)}`}
                target="_blank" rel="noopener noreferrer"
                className="inline-flex items-center gap-2 px-6 py-3 text-white font-medium rounded-xl text-sm transition-all"
                style={{ backgroundColor: '#25D366' }}>
                <WhatsappLogo size={18} /> Order via WhatsApp
              </a>
            )}
          </div>
        </div>
      </Container>
    </div>
  )
}

function RelatedProducts() {
  const navigate = useNavigate()
  const { id } = useParams()
  const item = c.catalogue.find((p) => p.id === id)
  if (!item) return null

  const related = c.catalogue.filter((p) => p.id !== id && p.available !== false && (p.category === item.category)).slice(0, 4)
  if (related.length === 0) return null

  return (
    <section className="border-t border-gray-100 py-10">
      <Container>
        <h2 className="text-lg font-bold text-gray-900 mb-5">You May Also Like</h2>
        <div className="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
          {related.map((p) => (
            <ProductCard key={p.id} item={p} />
          ))}
        </div>
      </Container>
    </section>
  )
}

function HomePage() {
  return (
    <div className="min-h-screen bg-white">
      <Nav />
      <HeroBanner />
      <CatalogueSection />
      <Footer />
      <WhatsAppFloat />
      <BackToTop />
    </div>
  )
}

export default function App() {
  return (
    <Routes>
      <Route path="/" element={<HomePage />} />
      <Route path="/product/:id" element={<><Nav /><ProductDetail /><RelatedProducts /><Footer /><WhatsAppFloat /><BackToTop /></>} />
    </Routes>
  )
}
