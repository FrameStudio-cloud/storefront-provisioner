import React, { useEffect, useMemo } from 'react'
import { Routes, Route, useParams, useNavigate } from 'react-router-dom'
import {
  Navbar,
  Hero,
  Container,
  Section,
  CatalogueGrid,
  CatalogueCard,
  Footer,
  WhatsAppFloat,
  BackToTop,
<% if (announcements.length > 0) { %>  AnnouncementBar,<% } %>
  Animate,
  ProductDetail,
  ImageWithFallback,
  Icon,
} from 'cite-ui'
import shopConfig from './config/site'

const c = shopConfig

const categoryIcons = {
  Dresses: 'heart',
  Tops: 'star',
  Bottoms: 'arrowDown',
  Jackets: 'settings',
  Shoes: 'user',
  Accessories: 'package',
  Bags: 'package',
  default: 'star',
}

function HomePage() {
  const navigate = useNavigate()

  const categories = useMemo(() => {
    return [...new Set(c.catalogue.map((item) => item.category).filter(Boolean))]
  }, [])

  const featuredItems = useMemo(() => {
    return c.catalogue.filter((item) => item.featured).slice(0, 8)
  }, [])

  return (
    <div className="min-h-screen bg-white">
<% if (announcements.length > 0) { %>
      {c.announcements.map((a, i) => (
        <AnnouncementBar key={i} text={a.text} variant={a.type} />
      ))}
<% } %>
      <Navbar
        logo={c.name}
        variant="transparent"
        links={[
          { label: 'Home', href: '/' },
          { label: 'New In', href: '/#new-arrivals' },
          { label: 'Shop', href: '/#catalogue' },
          { label: 'Contact', href: '/#contact' },
        ]}
        whatsapp={c.whatsapp}
      />

      <section id="home">
        <Hero
          variant="split"
          image={c.slides?.[0]?.image
            ? { src: c.slides[0].image, alt: c.name }
            : null
          }
          imagePosition="left"
          title={c.name}
          titleAccent={c.nameAccent ? ` ${c.nameAccent}` : ''}
          subtitle={c.tagline || c.description}
          primaryCta={{ label: 'Shop Now', href: '/#catalogue', size: 'lg' }}
          secondaryCta={c.whatsapp ? {
            label: 'Chat on WhatsApp',
            href: `https://wa.me/${c.whatsapp}`,
            variant: 'outline',
            size: 'lg',
          } : undefined}
        />
      </section>

      {categories.length > 1 && (
        <Section bg="bg-white" padding="md">
          <Container>
            <Animate type="slideUp" trigger="viewport">
              <h2 className="text-xl sm:text-2xl font-bold text-gray-900 mb-6 text-center">Categories</h2>
              <div className="flex gap-3 overflow-x-auto pb-2 scrollbar-hide snap-x">
                {categories.map((cat) => {
                  const iconName = categoryIcons[cat] || categoryIcons.default
                  const count = c.catalogue.filter((item) => item.category === cat).length
                  return (
                    <a
                      key={cat}
                      href={`/#catalogue?category=${encodeURIComponent(cat)}`}
                      className="flex flex-col items-center gap-2 min-w-[90px] snap-start p-4 rounded-2xl bg-gray-50 hover:bg-gray-100 border border-gray-200 hover:border-gray-300 transition-all group"
                    >
                      <div className="w-12 h-12 rounded-full bg-white shadow-sm flex items-center justify-center group-hover:shadow-md transition-shadow">
                        <Icon name={iconName} size={20} className="text-gray-600" />
                      </div>
                      <span className="text-xs font-medium text-gray-700 whitespace-nowrap">{cat}</span>
                      <span className="text-[10px] text-gray-400">{count} items</span>
                    </a>
                  )
                })}
              </div>
            </Animate>
          </Container>
        </Section>
      )}

      {featuredItems.length > 0 && (
        <section id="new-arrivals">
          <Section bg="bg-gray-50" padding="lg">
            <Container>
              <Animate type="slideUp" trigger="viewport">
                <div className="flex items-center justify-between mb-6">
                  <div>
                    <h2 className="text-2xl sm:text-3xl font-bold text-gray-900">New Arrivals</h2>
                    <p className="text-gray-500 mt-1">Our latest additions</p>
                  </div>
                  <a href="/#catalogue" className="text-sm font-medium text-black hover:underline hidden sm:block">
                    View All &rarr;
                  </a>
                </div>
                <div className="flex gap-5 overflow-x-auto pb-4 snap-x">
                  {featuredItems.map((item) => (
                    <div key={item.id} className="min-w-[220px] sm:min-w-[250px] snap-start">
                      <CatalogueCard
                        {...item}
                        badge={item.badge || 'New'}
                        onClick={() => navigate(`/product/${item.id}`)}
                      />
                    </div>
                  ))}
                </div>
                <a href="/#catalogue" className="text-sm font-medium text-black hover:underline mt-4 inline-block sm:hidden">
                  View All &rarr;
                </a>
              </Animate>
            </Container>
          </Section>
        </section>
      )}

      <Section bg="bg-black text-white" padding="xl">
        <Container maxWidth="lg">
          <Animate type="slideUp" trigger="viewport">
            <div className="text-center">
              <h2 className="text-3xl sm:text-4xl font-bold mb-4">Featured Collection</h2>
              <p className="text-gray-400 max-w-xl mx-auto mb-8 text-base leading-relaxed">
                Discover our handpicked selection of premium pieces. Quality you can feel, style you can see.
              </p>
              <a
                href="/#catalogue"
                className="inline-flex items-center justify-center bg-white text-gray-900 font-medium rounded-lg px-8 py-3 hover:bg-gray-200 transition-colors"
              >
                Explore Collection
              </a>
            </div>
          </Animate>
        </Container>
      </Section>

      <section id="catalogue">
        <Section padding="lg">
          <Container>
            <Animate type="slideUp" trigger="viewport">
              <h2 className="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">All Products</h2>
              <p className="text-gray-500 mb-8 max-w-2xl">Browse our full collection</p>
              <CatalogueGrid
                items={c.catalogue.map(item => ({
                  ...item,
                  cta: c.whatsapp
                    ? {
                        label: 'View Details',
                        onClick: () => navigate(`/product/${item.id}`),
                      }
                    : undefined,
                }))}
                searchable
                searchPlaceholder="Search products..."
                onItemClick={(item) => {
                  navigate(`/product/${item.id}`)
                }}
              />
            </Animate>
          </Container>
        </Section>
      </section>

      <footer id="contact">
        <Footer
          brand={c.name}
          description={c.tagline || ''}
          contact={[
            ...(c.whatsapp ? [{ icon: 'phone', label: 'WhatsApp', href: `https://wa.me/${c.whatsapp}`, value: c.whatsapp }] : []),
            ...(c.email ? [{ icon: 'mail', label: 'Email', href: `mailto:${c.email}`, value: c.email }] : []),
            ...(c.location ? [{ icon: 'mapPin', label: 'Location', value: c.location }] : []),
          ]}
          social={c.socialLinks && c.socialLinks.length > 0 ? c.socialLinks : []}
          businessHours={c.hours && c.hours.length > 0 ? c.hours : undefined}
          developerCredit={{
            name: c.developerName,
            whatsapp: c.developerWhatsapp,
          }}
        />
      </footer>

      <WhatsAppFloat phoneNumber={c.whatsapp} />
      <BackToTop />
    </div>
  )
}

function ProductPage() {
  const { id } = useParams()
  const navigate = useNavigate()
  const product = c.catalogue.find(item => String(item.id) === String(id))

  useEffect(() => {
    document.title = product
      ? `${product.title} — ${c.name}`
      : `Product not found — ${c.name}`
  }, [product])

  return (
    <div className="min-h-screen bg-white">
      <Navbar
        logo={c.name}
        variant="default"
        links={[
          { label: 'Home', href: '/' },
          { label: 'Shop', href: '/#catalogue' },
        ]}
        whatsapp={c.whatsapp}
      />

      <Section padding="md">
        <Container>
          <ProductDetail
            product={product}
            onBack={() => navigate('/')}
            onWhatsApp={c.whatsapp}
            currency={c.currency}
          />
        </Container>
      </Section>

      <Footer
        brand={c.name}
        description={c.tagline || ''}
        contact={[
          ...(c.whatsapp ? [{ icon: 'phone', label: 'WhatsApp', href: `https://wa.me/${c.whatsapp}`, value: c.whatsapp }] : []),
          ...(c.email ? [{ icon: 'mail', label: 'Email', href: `mailto:${c.email}`, value: c.email }] : []),
          ...(c.location ? [{ icon: 'mapPin', label: 'Location', value: c.location }] : []),
        ]}
        social={c.socialLinks && c.socialLinks.length > 0 ? c.socialLinks : []}
        businessHours={c.hours && c.hours.length > 0 ? c.hours : undefined}
        developerCredit={{
          name: c.developerName,
          whatsapp: c.developerWhatsapp,
        }}
      />

      <WhatsAppFloat phoneNumber={c.whatsapp} />
      <BackToTop />
    </div>
  )
}

export default function App() {
  return (
    <Routes>
      <Route path="/" element={<HomePage />} />
      <Route path="/product/:id" element={<ProductPage />} />
    </Routes>
  )
}
